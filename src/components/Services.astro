---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}
const { t } = Astro.props;

// SVG icons map
const icons: Record<string, string> = {
  home: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg>`,
  building: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M8 7h2m0 0h2M8 11h2m0 0h2M8 15h2m0 0h2M16 7h1M16 11h1M16 15h1"/></svg>`,
  hotel: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M3 21V5a2 2 0 012-2h14a2 2 0 012 2v16"/><path d="M1 21h22M9 7h1m4 0h1M9 11h1m4 0h1M9 15h6"/></svg>`,
  city: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M1 21h22M3 21V7l7-4v18M14 21V3l7 4v14"/><path d="M7 9v1m0 3v1m0 3v1M17 9v1m0 3v1m0 3v1"/></svg>`,
  restore: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10"/><path d="M22 12l-3-3-3 3"/><path d="M12 8v4l3 3"/></svg>`,
  interior: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="1"/><path d="M8 21h8M12 17v4"/><circle cx="12" cy="10" r="3"/></svg>`,
};
---

<section class="services section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <!-- Header -->
    <div class="services__header">
      <div class="reveal">
        <span class="eyebrow">{t.servicesEyebrow}</span>
      </div>
      <div class="services__title-row">
        <h2 class="heading heading-xl services__title reveal reveal-delay-1" id="services-heading">
          {t.servicesTitle.split('\n').map((line) => (
            <span class="block">{line}</span>
          ))}
        </h2>
        <p class="body-lg services__subtitle reveal reveal-delay-2">
          {t.servicesSubtitle}
        </p>
      </div>
    </div>

    <!-- Services Grid -->
    <div class="services__grid" role="list">
      {t.services.map((service, i) => (
        <article
          class="service-card reveal"
          style={`--delay: ${(i % 3) * 100}ms`}
          role="listitem"
        >
          <div class="service-card__icon" aria-hidden="true" set:html={icons[service.icon]} />
          <div class="service-card__num" aria-hidden="true">0{i + 1}</div>
          <h3 class="service-card__title heading heading-sm">{service.title}</h3>
          <p class="service-card__desc">{service.desc}</p>
          <div class="service-card__line" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ─── Services Section ─── */
  .services {
    background: var(--color-offwhite);
    position: relative;
  }

  .services::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-sand-light), transparent);
  }

  /* ─── Header ─── */
  .services__header {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .services__title-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap);
    align-items: end;
  }

  .services__title {
    white-space: pre-line;
  }

  .block {
    display: block;
  }

  .services__subtitle {
    padding-bottom: 0.25rem;
    max-width: 400px;
  }

  /* ─── Grid ─── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--color-sand-light);
  }

  /* ─── Card ─── */
  .service-card {
    padding: clamp(1.75rem, 4vw, 2.75rem);
    border-right: 1px solid var(--color-sand-light);
    border-bottom: 1px solid var(--color-sand-light);
    position: relative;
    overflow: hidden;
    transition: background 400ms var(--ease-out);
    transition-delay: var(--delay);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-card:nth-child(3n) {
    border-right: none;
  }

  .service-card:nth-last-child(-n+3) {
    border-bottom: none;
  }

  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-charcoal);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 500ms var(--ease-out);
    z-index: 0;
  }

  .service-card:hover::before {
    transform: scaleY(1);
  }

  .service-card:hover .service-card__title,
  .service-card:hover .service-card__desc,
  .service-card:hover .service-card__num,
  .service-card:hover .service-card__icon,
  .service-card:hover .service-card__line {
    color: var(--color-offwhite);
  }

  .service-card:hover .service-card__line {
    background: rgba(247, 244, 239, 0.2);
  }

  /* ─── Card elements ─── */
  .service-card__icon {
    width: 2rem;
    height: 2rem;
    color: var(--color-sand);
    position: relative;
    z-index: 1;
    transition: color 400ms;
    flex-shrink: 0;
  }

  .service-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .service-card__num {
    position: absolute;
    top: 1.5rem;
    inset-inline-end: 1.75rem;
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--color-sand-light);
    line-height: 1;
    z-index: 0;
    transition: color 400ms;
    pointer-events: none;
    user-select: none;
  }

  .service-card__title {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-charcoal);
    position: relative;
    z-index: 1;
    transition: color 400ms;
    margin-top: 0.5rem;
  }

  .service-card__desc {
    font-size: 0.875rem;
    color: var(--color-stone);
    line-height: 1.7;
    position: relative;
    z-index: 1;
    transition: color 400ms;
    flex: 1;
  }

  .service-card__line {
    width: 1.5rem;
    height: 1px;
    background: var(--color-sand);
    position: relative;
    z-index: 1;
    transition: background 400ms, width 300ms;
    margin-top: auto;
  }

  .service-card:hover .service-card__line {
    width: 2.5rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
    .service-card:nth-child(3n) { border-right: 1px solid var(--color-sand-light); }
    .service-card:nth-child(2n) { border-right: none; }
    .service-card:nth-last-child(-n+3) { border-bottom: 1px solid var(--color-sand-light); }
    .service-card:nth-last-child(-n+2) { border-bottom: none; }
  }

  @media (max-width: 768px) {
    .services__title-row { grid-template-columns: 1fr; }
    .services__grid { grid-template-columns: 1fr; }
    .service-card { border-right: none !important; }
    .service-card:last-child { border-bottom: none; }
    .service-card:nth-last-child(-n+3) { border-bottom: 1px solid var(--color-sand-light); }
  }
</style>
