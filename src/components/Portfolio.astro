---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}
const { t } = Astro.props;

// High-quality Unsplash architecture images (CC0/Free)
const portfolioImages = [
  'https://images.unsplash.com/photo-1600210492493-0946911123ea?auto=format&fit=crop&w=900&q=80',
  'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=900&q=80',
  'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=900&q=80',
  'https://images.unsplash.com/photo-1605276374104-dee2a0ed3cd6?auto=format&fit=crop&w=900&q=80',
  'https://images.unsplash.com/photo-1577495508048-b635879837f1?auto=format&fit=crop&w=900&q=80',
  'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=900&q=80',
];
---

<section class="portfolio section" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <!-- Header -->
    <div class="portfolio__header">
      <div class="portfolio__header-left">
        <span class="eyebrow reveal">{t.portfolioEyebrow}</span>
        <h2 class="heading heading-xl portfolio__title reveal reveal-delay-1" id="portfolio-heading">
          {t.portfolioTitle.split('\n').map((line) => (
            <span class="block">{line}</span>
          ))}
        </h2>
      </div>
      <p class="body-lg portfolio__subtitle reveal reveal-delay-2">{t.portfolioSubtitle}</p>
    </div>
  </div>

  <!-- Portfolio Grid (full-bleed) -->
  <div class="portfolio__grid" role="list">
    {t.projects.map((project, i) => (
      <article
        class="portfolio-item reveal"
        style={`--delay: ${i * 80}ms`}
        role="listitem"
        data-hover
      >
        <div class="portfolio-item__img-wrap">
          <img
            src={portfolioImages[i]}
            alt={`${project.title} — ${project.category}, ${project.location}`}
            class="portfolio-item__img"
            loading="lazy"
            width="900"
            height="600"
          />
        </div>
        <div class="portfolio-item__info">
          <div class="portfolio-item__meta">
            <span class="portfolio-item__cat eyebrow">{project.category}</span>
            <span class="portfolio-item__year">{project.year}</span>
          </div>
          <h3 class="portfolio-item__title heading heading-sm">{project.title}</h3>
          <p class="portfolio-item__loc">{project.location}</p>
          <span class="portfolio-item__cta btn" aria-hidden="true">
            <span>{t.portfolioCta}</span>
            <span class="btn-arrow"></span>
          </span>
        </div>
      </article>
    ))}
  </div>

  <div class="container portfolio__footer">
    <a href="#contact" class="btn-outline reveal">
      {t.portfolioViewAll}
    </a>
  </div>
</section>

<style>
  /* ─── Portfolio Section ─── */
  .portfolio {
    background: var(--color-charcoal);
    color: var(--color-offwhite);
    overflow: hidden;
  }

  /* ─── Header ─── */
  .portfolio__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .portfolio__header-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .portfolio__header .eyebrow {
    color: var(--color-sand);
  }

  .portfolio__title {
    color: var(--color-offwhite);
  }

  .block { display: block; }

  .portfolio__subtitle {
    color: var(--color-stone-light);
    align-self: end;
  }

  /* ─── Grid ─── */
  .portfolio__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(247, 244, 239, 0.08);
    margin-block: 0;
  }

  /* ─── Item ─── */
  .portfolio-item {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--color-charcoal);
    cursor: pointer;
    transition-delay: var(--delay);
  }

  .portfolio-item__img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .portfolio-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-out), filter 500ms;
    filter: grayscale(20%) brightness(0.85);
  }

  .portfolio-item:hover .portfolio-item__img {
    transform: scale(1.07);
    filter: grayscale(0%) brightness(0.7);
  }

  /* ─── Info overlay ─── */
  .portfolio-item__info {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    background: linear-gradient(
      to top,
      rgba(28, 26, 24, 0.9) 0%,
      rgba(28, 26, 24, 0.4) 50%,
      transparent 100%
    );
    transform: translateY(3rem);
    transition: transform 500ms var(--ease-out);
    z-index: 1;
  }

  .portfolio-item:hover .portfolio-item__info {
    transform: translateY(0);
  }

  .portfolio-item__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .portfolio-item__cat {
    color: var(--color-sand);
  }

  .portfolio-item__year {
    font-size: 0.6875rem;
    color: rgba(247, 244, 239, 0.5);
    letter-spacing: 0.1em;
  }

  .portfolio-item__title {
    color: var(--color-offwhite);
    font-size: 1.3rem;
    font-weight: 400;
    margin-bottom: 0.25rem;
  }

  .portfolio-item__loc {
    font-size: 0.75rem;
    color: rgba(247, 244, 239, 0.55);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .portfolio-item__cta {
    color: var(--color-sand);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 400ms, transform 400ms var(--ease-out);
    transition-delay: 80ms;
  }

  .portfolio-item:hover .portfolio-item__cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Footer ─── */
  .portfolio__footer {
    padding-block: clamp(2.5rem, 5vw, 4rem) 0;
    display: flex;
    justify-content: center;
  }

  .btn-outline {
    border-color: rgba(247, 244, 239, 0.3);
    color: var(--color-offwhite);
  }

  .btn-outline:hover {
    background: var(--color-offwhite);
    color: var(--color-charcoal);
    border-color: var(--color-offwhite);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .portfolio__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .portfolio__header { grid-template-columns: 1fr; }
    .portfolio__grid { grid-template-columns: 1fr; }
    .portfolio-item { aspect-ratio: 4/3; }
    .portfolio-item__info { transform: translateY(0); }
    .portfolio-item__cta { opacity: 1; transform: translateY(0); }
  }
</style>
