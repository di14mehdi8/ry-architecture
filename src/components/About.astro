---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}
const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="about section" id="about" aria-labelledby="about-heading">
  <div class="container">
    <div class="about__grid">
      <!-- Image column -->
      <div class="about__image-col reveal">
        <div class="about__image-wrap">
          <img
            src={`${base}/images/yassir-rafi.jpg`}
            alt="Yassir Rafi — Architecte fondateur de RY Architecture à Marrakech"
            class="about__image"
            loading="lazy"
            width="600"
            height="750"
          />
          <div class="about__image-caption" aria-hidden="true">
            <span>Yassir Rafi</span>
            <span class="about__image-rule"></span>
            <span>Architecte · Marrakech</span>
          </div>
        </div>
        <!-- Decorative element -->
        <div class="about__deco" aria-hidden="true">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="1" width="198" height="198" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 8"/>
          </svg>
        </div>
      </div>

      <!-- Content column -->
      <div class="about__content">
        <span class="eyebrow reveal">{t.aboutEyebrow}</span>

        <div class="about__name-block reveal reveal-delay-1">
          <h2 class="heading heading-xl about__name" id="about-heading">{t.aboutTitle}</h2>
          <span class="about__subtitle">{t.aboutSubtitle}</span>
          <div class="line about__line" aria-hidden="true"></div>
        </div>

        <div class="about__bio">
          <p class="reveal reveal-delay-2">{t.aboutBio1}</p>
          <p class="reveal reveal-delay-3">{t.aboutBio2}</p>
          <p class="reveal reveal-delay-4">{t.aboutBio3}</p>
        </div>

        <blockquote class="about__quote reveal reveal-delay-4">
          <p class="about__quote-text heading heading-sm">
            {t.aboutQuote}
          </p>
          <cite class="about__quote-author">{t.aboutQuoteAuthor}</cite>
        </blockquote>

        <!-- Credentials -->
        <div class="about__credentials reveal reveal-delay-5">
          <div class="credential">
            <span class="credential__label eyebrow">Formation</span>
            <span class="credential__value">École Nationale d'Architecture, Rabat</span>
          </div>
          <div class="credential">
            <span class="credential__label eyebrow">Basé à</span>
            <span class="credential__value">Marrakech, Maroc</span>
          </div>
          <div class="credential">
            <span class="credential__label eyebrow">Expérience</span>
            <span class="credential__value">15 ans · 120+ projets</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── About Section ─── */
  .about {
    background: var(--color-offwhite);
    position: relative;
    overflow: hidden;
  }

  .about::after {
    content: 'RY';
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    font-family: var(--font-heading);
    font-size: 18vw;
    font-weight: 300;
    color: var(--color-sand-light);
    opacity: 0.3;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  [dir="rtl"] .about::after {
    right: auto;
    left: -1rem;
  }

  /* ─── Grid ─── */
  .about__grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: clamp(3rem, 7vw, 7rem);
    align-items: center;
  }

  [dir="rtl"] .about__grid {
    direction: rtl;
  }

  /* ─── Image ─── */
  .about__image-col {
    position: relative;
  }

  .about__image-wrap {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
  }

  .about__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 700ms var(--ease-out);
    filter: grayscale(8%) contrast(1.05);
  }

  .about__image-wrap:hover .about__image {
    transform: scale(1.03);
  }

  .about__image-caption {
    position: absolute;
    bottom: 1.5rem;
    left: -1.5rem;
    background: var(--color-offwhite);
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-stone);
  }

  [dir="rtl"] .about__image-caption {
    left: auto;
    right: -1.5rem;
  }

  .about__image-rule {
    display: block;
    width: 1.5rem;
    height: 1px;
    background: var(--color-sand);
  }

  .about__deco {
    position: absolute;
    top: -1.5rem;
    left: -1.5rem;
    width: 6rem;
    height: 6rem;
    color: var(--color-sand);
    opacity: 0.4;
    pointer-events: none;
  }

  [dir="rtl"] .about__deco {
    left: auto;
    right: -1.5rem;
  }

  /* ─── Content ─── */
  .about__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  .about__name-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about__name {
    font-style: italic;
  }

  .about__subtitle {
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    color: var(--color-stone);
    text-transform: uppercase;
  }

  .about__line {
    margin-top: 0.75rem;
    width: 2.5rem;
    background: var(--color-sand);
  }

  /* ─── Bio ─── */
  .about__bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about__bio p {
    font-size: 1rem;
    color: var(--color-stone);
    line-height: 1.8;
  }

  /* ─── Quote ─── */
  .about__quote {
    border-left: 2px solid var(--color-sand);
    padding-left: 1.75rem;
    margin: 0.5rem 0;
  }

  [dir="rtl"] .about__quote {
    border-left: none;
    border-right: 2px solid var(--color-sand);
    padding-left: 0;
    padding-right: 1.75rem;
  }

  .about__quote-text {
    font-style: italic;
    color: var(--color-charcoal);
    font-size: 1.15rem;
    line-height: 1.5;
    font-weight: 300;
  }

  .about__quote-author {
    display: block;
    font-style: normal;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-stone);
    margin-top: 0.75rem;
  }

  /* ─── Credentials ─── */
  .about__credentials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-sand-light);
  }

  .credential {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
  }

  .credential__label {
    min-width: 7rem;
    flex-shrink: 0;
    color: var(--color-stone);
  }

  .credential__value {
    font-size: 0.875rem;
    color: var(--color-charcoal);
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about__image-wrap { aspect-ratio: 3/2; }
    .about__image-caption { display: none; }
  }
</style>
