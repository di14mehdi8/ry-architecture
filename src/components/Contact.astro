---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}
const { t } = Astro.props;

const addressLines = t.contactAddress.split('\n');
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <!-- Top decorative strip: mosaic texture -->
  <div class="contact__mosaic" aria-hidden="true">
    {Array.from({ length: 20 }).map((_, i) => (
      <div class="mosaic-cell" style={`--i: ${i}`}></div>
    ))}
  </div>

  <div class="container">
    <div class="contact__layout">
      <!-- Left: Big CTA text -->
      <div class="contact__left">
        <span class="eyebrow contact__eyebrow reveal">{t.contactEyebrow}</span>
        <h2 class="heading heading-display contact__title reveal reveal-delay-1" id="contact-heading">
          {t.contactTitle.split('\n').map((line) => (
            <span class="block">{line}</span>
          ))}
        </h2>
        <p class="contact__subtitle reveal reveal-delay-2">{t.contactSubtitle}</p>

        <!-- Contact details -->
        <div class="contact__details reveal reveal-delay-3">
          <a href={`mailto:${t.contactEmail}`} class="contact__detail">
            <span class="contact__detail-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <rect x="2" y="4" width="16" height="12" rx="1"/>
                <path d="M2 6l8 6 8-6"/>
              </svg>
            </span>
            <span>{t.contactEmail}</span>
          </a>
          <a href={`tel:${t.contactPhone.replace(/\s/g, '')}`} class="contact__detail">
            <span class="contact__detail-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <path d="M5 2h3l1.5 4L8 8s1 2 4 4l1.5-1.5L17 12v3s-2 3-5 1C8 14 6 8 5 5S4 2 5 2z"/>
              </svg>
            </span>
            <span>{t.contactPhone}</span>
          </a>
          <address class="contact__detail contact__address" aria-label="Adresse">
            <span class="contact__detail-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <path d="M10 18s-7-6-7-10a7 7 0 1114 0c0 4-7 10-7 10z"/>
                <circle cx="10" cy="8" r="2.5"/>
              </svg>
            </span>
            <span>
              {addressLines.map((line, i) => (
                <>
                  {line}
                  {i < addressLines.length - 1 && <br />}
                </>
              ))}
            </span>
          </address>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="contact__form-col reveal reveal-delay-2">
        <form
          class="contact__form"
          id="contact-form"
          novalidate
          aria-label="Formulaire de contact"
        >
          <div class="form-field">
            <label class="form-label" for="contact-name">{t.contactNameLabel}</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              class="form-input"
              placeholder={t.contactNamePlaceholder}
              required
              autocomplete="name"
            />
            <span class="form-error" role="alert"></span>
          </div>

          <div class="form-field">
            <label class="form-label" for="contact-email">{t.contactEmailLabel}</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              class="form-input"
              placeholder={t.contactEmailPlaceholder}
              required
              autocomplete="email"
            />
            <span class="form-error" role="alert"></span>
          </div>

          <div class="form-field">
            <label class="form-label" for="contact-project">{t.contactProjectLabel}</label>
            <textarea
              id="contact-project"
              name="project"
              class="form-input form-textarea"
              placeholder={t.contactProjectPlaceholder}
              rows="5"
              required
            ></textarea>
            <span class="form-error" role="alert"></span>
          </div>

          <button type="submit" class="form-submit">
            <span class="form-submit__text">{t.contactSubmit}</span>
            <span class="form-submit__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </span>
          </button>

          <!-- Success message -->
          <div class="form-success" id="form-success" hidden role="status" aria-live="polite">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 12l3 3 5-5"/>
            </svg>
            <p>Message envoyé avec succès. Nous vous répondrons sous 48h.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Contact Section ─── */
  .contact {
    background: var(--color-charcoal);
    color: var(--color-offwhite);
    padding-block: var(--section-y);
    position: relative;
    overflow: hidden;
  }

  /* ─── Mosaic top strip ─── */
  .contact__mosaic {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    display: flex;
  }

  .mosaic-cell {
    flex: 1;
    background: var(--color-sand);
    opacity: calc(0.3 + (var(--i) % 5) * 0.1);
  }

  /* ─── Layout ─── */
  .contact__layout {
    display: grid;
    grid-template-columns: 5fr 5fr;
    gap: clamp(3rem, 8vw, 8rem);
    align-items: start;
  }

  /* ─── Left column ─── */
  .contact__left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact__eyebrow {
    color: var(--color-sand);
  }

  .contact__title {
    color: var(--color-offwhite);
    font-style: italic;
    line-height: 0.95;
  }

  .block { display: block; }

  .contact__subtitle {
    font-size: 1rem;
    color: rgba(247, 244, 239, 0.6);
    line-height: 1.75;
    max-width: 380px;
  }

  /* ─── Details ─── */
  .contact__details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(247, 244, 239, 0.1);
  }

  .contact__detail {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: rgba(247, 244, 239, 0.65);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 200ms;
    font-style: normal;
  }

  .contact__detail:hover {
    color: var(--color-offwhite);
  }

  .contact__detail-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--color-sand);
  }

  .contact__detail-icon svg {
    width: 100%;
    height: 100%;
  }

  .contact__address {
    align-items: flex-start;
    line-height: 1.7;
  }

  /* ─── Form ─── */
  .contact__form-col {
    padding: clamp(2rem, 4vw, 3.5rem);
    background: rgba(247, 244, 239, 0.04);
    border: 1px solid rgba(247, 244, 239, 0.08);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ─── Form Fields ─── */
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(247, 244, 239, 0.5);
  }

  .form-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(247, 244, 239, 0.15);
    color: var(--color-offwhite);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 0;
    transition: border-color 300ms;
    outline: none;
    width: 100%;
    -webkit-appearance: none;
  }

  .form-input::placeholder {
    color: rgba(247, 244, 239, 0.2);
  }

  .form-input:focus {
    border-bottom-color: var(--color-sand);
  }

  .form-input.error {
    border-bottom-color: #c0392b;
  }

  .form-textarea {
    resize: none;
    min-height: 100px;
  }

  .form-error {
    font-size: 0.75rem;
    color: #e07070;
    min-height: 1em;
  }

  /* ─── Submit Button ─── */
  .form-submit {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: var(--color-sand);
    color: var(--color-charcoal);
    border: none;
    padding: 1.25rem 1.75rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
    transition: background 300ms, transform 200ms var(--ease-out);
    margin-top: 0.5rem;
  }

  .form-submit::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-offwhite);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 400ms var(--ease-out);
  }

  .form-submit:hover::before {
    transform: scaleX(1);
  }

  .form-submit__text,
  .form-submit__arrow {
    position: relative;
    z-index: 1;
  }

  .form-submit__arrow {
    width: 1.5rem;
    height: 1.5rem;
    transition: transform 300ms var(--ease-out);
  }

  .form-submit:hover .form-submit__arrow {
    transform: translateX(4px);
  }

  .form-submit__arrow svg {
    width: 100%;
    height: 100%;
  }

  /* ─── Success ─── */
  .form-success {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(201, 180, 154, 0.12);
    border: 1px solid rgba(201, 180, 154, 0.3);
    color: var(--color-sand);
  }

  .form-success[hidden] { display: none; }

  .form-success svg {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  .form-success p {
    font-size: 0.875rem;
    color: rgba(247, 244, 239, 0.8);
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .contact__layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .contact__form-col {
      padding: 1.5rem;
    }
  }
</style>

<script>
  // ─── Form Validation & Submission ───
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    let valid = true;

    // Clear previous errors
    form.querySelectorAll('.form-error').forEach(el => el.textContent = '');
    form.querySelectorAll('.form-input').forEach(el => el.classList.remove('error'));

    const nameInput = form.querySelector<HTMLInputElement>('#contact-name');
    const emailInput = form.querySelector<HTMLInputElement>('#contact-email');
    const projectInput = form.querySelector<HTMLTextAreaElement>('#contact-project');

    if (!nameInput?.value.trim()) {
      const err = nameInput?.closest('.form-field')?.querySelector('.form-error');
      if (err) err.textContent = 'Ce champ est requis.';
      nameInput?.classList.add('error');
      valid = false;
    }

    if (!emailInput?.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
      const err = emailInput?.closest('.form-field')?.querySelector('.form-error');
      if (err) err.textContent = 'Veuillez entrer une adresse e-mail valide.';
      emailInput?.classList.add('error');
      valid = false;
    }

    if (!projectInput?.value.trim()) {
      const err = projectInput?.closest('.form-field')?.querySelector('.form-error');
      if (err) err.textContent = 'Ce champ est requis.';
      projectInput?.classList.add('error');
      valid = false;
    }

    if (!valid) return;

    // Simulate submission (replace with actual endpoint)
    const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement | null;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.querySelector('.form-submit__text')!.textContent = '...';
    }

    await new Promise(r => setTimeout(r, 1200));

    form.reset();
    form.style.display = 'none';
    if (successMsg) successMsg.hidden = false;
  });
</script>
